; draw
(gl:set-renderer (lambda ()
   (glClear (bor GL_COLOR_BUFFER_BIT GL_DEPTH_BUFFER_BIT))

   (glMatrixMode GL_PROJECTION)
   (glLoadIdentity)
   (gluPerspective 45 (/ (gl:get-window-width) (gl:get-window-height)) 0.1 100)

   (glMatrixMode GL_MODELVIEW)
   (glLoadIdentity)

   (gluLookAt
      -0.278 0.273 0.8
      -0.278 0.273 -0.2
      0 1 0)

   ;; (glLightfv GL_LIGHT0 GL_POSITION '(-0.278 0.540 -0.2795 1.0))
   (glLightfv GL_LIGHT0 GL_POSITION '(-0.278 0.51 -0.2795  1.0))

   (define (vertex x y z  nx ny nz  u v  c)
      (define color (ref colors c))
      ;; (glTexCoord2f u v)
      (glColor3fv color)
      (glNormal3f nx ny nz)
      (glVertex3f x y z))

   (glBegin GL_TRIANGLES)
      (for-each (lambda (i)
            (apply vertex (ref vertices i)))
         indices)
   (glEnd)

